# Which environment this process is running in — surfaced in GET /health so
# you can confirm at a glance which environment you're actually hitting.
ENVIRONMENT=development

# Connection string for the primary database. The default below matches
# docker-compose.yml's "db" service — override it if you're running Postgres
# somewhere else.
DATABASE_URL=postgresql+asyncpg://opsmind:opsmind@localhost:5432/opsmind

# Connection pool sizing — see core/database.py. Defaults match
# SQLAlchemy's own built-ins; tune per-environment once real load testing
# gives you a reason to.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Local directory where uploaded document bytes are written (see
# core/storage.py). Override in production to a path on persistent,
# non-ephemeral storage.
STORAGE_DIR=storage/documents

# Maximum accepted upload size, in bytes. Default: 20 MB.
MAX_UPLOAD_SIZE_BYTES=20971520
